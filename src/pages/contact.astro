---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact Us | North Country Realty Group">
  <Header />
  
  <main id="main-content">
    <!-- Page Hero -->
    <section class="bg-navy py-16 md:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
        <div class="mx-auto mb-6 h-1 w-16 bg-accent"></div>
        <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-4 text-balance">
          Contact Us
        </h1>
        <p class="text-lg text-white max-w-2xl mx-auto text-pretty">
          We'd love to hear from you. Reach out to schedule a consultation or ask us anything.
        </p>
      </div>
    </section>

    <!-- Two Column Layout: Form + Contact Info -->
    <section class="py-16 md:py-20 bg-white">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
          
          <!-- Left Column: Contact Form -->
          <div>
            <h2 class="font-heading text-2xl md:text-3xl font-bold text-primary mb-6">
              Send Us a Message
            </h2>
            
            <form id="consultation" class="space-y-6">
              <!-- Full Name -->
              <div>
                <label for="full-name" class="block text-sm font-medium text-slate-700 mb-2">
                  Full Name <span class="text-red-600">*</span>
                </label>
                <input
                  type="text"
                  id="full-name"
                  name="full-name"
                  required
                  aria-required="true"
                  class="w-full rounded-lg border border-slate-300 px-4 py-3 text-slate-900 placeholder-slate-400 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20 transition-colors"
                />
              </div>

              <!-- Email Address -->
              <div>
                <label for="email" class="block text-sm font-medium text-slate-700 mb-2">
                  Email Address <span class="text-red-600">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  aria-required="true"
                  class="w-full rounded-lg border border-slate-300 px-4 py-3 text-slate-900 placeholder-slate-400 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20 transition-colors"
                />
              </div>

              <!-- Phone Number (Optional) -->
              <div>
                <label for="phone" class="block text-sm font-medium text-slate-700 mb-2">
                  Phone Number <span class="text-slate-400">(optional)</span>
                </label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  class="w-full rounded-lg border border-slate-300 px-4 py-3 text-slate-900 placeholder-slate-400 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20 transition-colors"
                />
              </div>

              <!-- Subject Dropdown -->
              <div>
                <label for="subject" class="block text-sm font-medium text-slate-700 mb-2">
                  Subject <span class="text-red-600">*</span>
                </label>
                <select
                  id="subject"
                  name="subject"
                  required
                  aria-required="true"
                  class="w-full rounded-lg border border-slate-300 px-4 py-3 text-slate-900 bg-white focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20 transition-colors"
                >
                  <option value="">Select a subject</option>
                  <option value="general">General Inquiry</option>
                  <option value="consultation">Schedule a Consultation</option>
                  <option value="buying">Buying a Home</option>
                  <option value="selling">Selling a Home</option>
                  <option value="other">Other</option>
                </select>
              </div>

              <!-- Message -->
              <div>
                <label for="message" class="block text-sm font-medium text-slate-700 mb-2">
                  Message <span class="text-red-600">*</span>
                </label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  required
                  aria-required="true"
                  class="w-full rounded-lg border border-slate-300 px-4 py-3 text-slate-900 placeholder-slate-400 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20 transition-colors resize-vertical"
                ></textarea>
              </div>

              <!-- Submit Button -->
              <button
                type="submit"
                class="w-full rounded-lg bg-accent px-6 py-4 text-base font-semibold text-primary hover:bg-accent/90 focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 transition-colors"
              >
                Send Message
              </button>

              <!-- Success Message (hidden by default) -->
              <div
                id="form-success"
                role="alert"
                class="hidden rounded-lg bg-green-50 border border-green-200 p-4 text-green-800"
              >
                <p class="font-medium">Thank you for your message!</p>
                <p class="text-sm mt-1">We'll get back to you within 1-2 business days.</p>
              </div>
            </form>
          </div>

          <!-- Right Column: Contact Info -->
          <div>
            <h2 class="font-heading text-2xl md:text-3xl font-bold text-primary mb-6">
              Get in Touch
            </h2>

            <address class="not-italic space-y-6">
              <!-- Office Address -->
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center">
                  <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-slate-900">Office Address</p>
                  <p class="text-slate-600">123 Main Street<br />Lancaster, NH 03584</p>
                </div>
              </div>

              <!-- Phone -->
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center">
                  <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-slate-900">Phone</p>
                  <a href="tel:+16037881234" class="text-accent hover:text-accent/80 transition-colors">
                    (603) 788-1234
                  </a>
                </div>
              </div>

              <!-- Email -->
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center">
                  <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-slate-900">Email</p>
                  <a href="mailto:info@northcountryrealty.com" class="text-accent hover:text-accent/80 transition-colors">
                    info@northcountryrealty.com
                  </a>
                </div>
              </div>

              <!-- Office Hours -->
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center">
                  <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-slate-900">Office Hours</p>
                  <p class="text-slate-600">Mon–Fri: 9am–5pm</p>
                  <p class="text-slate-600">Sat: 10am–2pm</p>
                  <p class="text-slate-600">Sun: Closed</p>
                </div>
              </div>
            </address>

            <!-- Static Map Placeholder -->
            <div class="mt-8 rounded-xl bg-primary p-8 flex flex-col items-center justify-center min-h-[200px]">
              <svg class="w-12 h-12 text-accent mb-3" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" />
              </svg>
              <p class="text-white font-semibold text-center">123 Main Street</p>
              <p class="text-slate-300 text-sm text-center">Lancaster, NH 03584</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="py-16 md:py-20 bg-slate-50">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <div class="mx-auto mb-4 h-1 w-16 bg-accent"></div>
          <h2 class="font-heading text-2xl md:text-3xl font-bold text-primary">
            Frequently Asked Questions
          </h2>
        </div>

        <div class="space-y-4">
          <!-- FAQ Item 1 -->
          <details class="group rounded-lg border border-slate-200 bg-white">
            <summary class="flex cursor-pointer items-center justify-between p-6 font-semibold text-slate-900 hover:bg-slate-50 transition-colors list-none">
              <span>How do I get started buying a home?</span>
              <svg class="w-5 h-5 text-accent transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-6 text-slate-600">
              <p>The first step is to get pre-approved for a mortgage so you know your budget. Then, contact us to schedule a consultation where we'll discuss your needs, preferred locations, and timeline. We'll guide you through every step of the home buying process, from searching listings to closing day.</p>
            </div>
          </details>

          <!-- FAQ Item 2 -->
          <details class="group rounded-lg border border-slate-200 bg-white">
            <summary class="flex cursor-pointer items-center justify-between p-6 font-semibold text-slate-900 hover:bg-slate-50 transition-colors list-none">
              <span>What areas do you serve?</span>
              <svg class="w-5 h-5 text-accent transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-6 text-slate-600">
              <p>We proudly serve the North Country region of New Hampshire, including Lancaster, Littleton, Whitefield, Jefferson, Dalton, and surrounding communities in Coos and Grafton counties. Our deep knowledge of these areas helps us find the perfect property for your needs.</p>
            </div>
          </details>

          <!-- FAQ Item 3 -->
          <details class="group rounded-lg border border-slate-200 bg-white">
            <summary class="flex cursor-pointer items-center justify-between p-6 font-semibold text-slate-900 hover:bg-slate-50 transition-colors list-none">
              <span>How long does it take to sell a home?</span>
              <svg class="w-5 h-5 text-accent transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-6 text-slate-600">
              <p>The timeline varies based on market conditions, pricing, and property type. On average, well-priced homes in our area sell within 30-90 days. We'll provide a detailed market analysis and work with you to develop a pricing and marketing strategy that meets your goals.</p>
            </div>
          </details>

          <!-- FAQ Item 4 -->
          <details class="group rounded-lg border border-slate-200 bg-white">
            <summary class="flex cursor-pointer items-center justify-between p-6 font-semibold text-slate-900 hover:bg-slate-50 transition-colors list-none">
              <span>Do I need a real estate agent to buy or sell?</span>
              <svg class="w-5 h-5 text-accent transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-6 text-slate-600">
              <p>While it's legally possible to buy or sell without an agent, having professional representation protects your interests and often results in better outcomes. We handle negotiations, paperwork, inspections, and the many details involved in real estate transactions, saving you time and potential costly mistakes.</p>
            </div>
          </details>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  const form = document.getElementById('consultation') as HTMLFormElement;
  const successMessage = document.getElementById('form-success');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    
    // In a real application, you would submit the form data to a server here
    // For now, we'll just show the success message
    
    if (successMessage) {
      successMessage.classList.remove('hidden');
      form.reset();
      
      // Scroll to success message
      successMessage.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  });
</script>
