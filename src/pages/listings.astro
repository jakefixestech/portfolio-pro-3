---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const propertyTypes = ["All", "Single Family", "Condo", "Land", "Commercial"];
const towns = ["All", "Lancaster", "Whitefield", "Groveton", "Jefferson", "Dalton"];
const priceRanges = ["All", "Under $200k", "$200k–$400k", "$400k+"];

const listings = [
  {
    id: 1,
    address: "47 Pine Street, Lancaster, NH",
    price: "$325,000",
    beds: 3,
    baths: 2,
    sqft: "1,850",
    type: "Single Family",
    status: "Active",
  },
  {
    id: 2,
    address: "182 Main Street, Whitefield, NH",
    price: "$275,000",
    beds: 4,
    baths: 2.5,
    sqft: "2,100",
    type: "Single Family",
    status: "Active",
  },
  {
    id: 3,
    address: "15 Mountain View Dr, Jefferson, NH",
    price: "$450,000",
    beds: 5,
    baths: 3,
    sqft: "3,200",
    type: "Single Family",
    status: "Active",
  },
  {
    id: 4,
    address: "89 River Road, Groveton, NH",
    price: "$189,000",
    beds: 2,
    baths: 1,
    sqft: "1,200",
    type: "Condo",
    status: "Active",
  },
  {
    id: 5,
    address: "Lot 12 Forest Lane, Dalton, NH",
    price: "$75,000",
    beds: 0,
    baths: 0,
    sqft: "5 acres",
    type: "Land",
    status: "Active",
  },
  {
    id: 6,
    address: "220 Commercial Ave, Lancaster, NH",
    price: "$525,000",
    beds: 0,
    baths: 2,
    sqft: "4,500",
    type: "Commercial",
    status: "Active",
  },
];
---

<Layout title="Listings | North Country Realty Group">
  <Header />
  <main id="main-content" class="flex-1">
    <!-- Page Hero -->
    <section class="bg-navy py-16 lg:py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="inline-block w-16 h-1 bg-gold mb-6" aria-hidden="true"></div>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-white mb-4">
          Browse Our Listings
        </h1>
        <p class="text-lg text-gray-300 max-w-2xl mx-auto">
          Explore available properties across Lancaster, NH and the surrounding North Country region.
        </p>
      </div>
    </section>

    <!-- Filter Bar -->
    <section class="bg-gray-50 border-b border-gray-200 py-6">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <form class="flex flex-col sm:flex-row gap-4" aria-label="Filter listings">
          <div class="flex-1">
            <label for="property-type" class="block text-sm font-medium text-gray-700 mb-1">
              Property Type
            </label>
            <select
              id="property-type"
              name="property-type"
              class="w-full px-4 py-2.5 border border-navy rounded-md bg-white text-gray-800 focus:ring-2 focus:ring-gold focus:border-gold transition-colors"
              aria-label="Filter by property type"
            >
              {propertyTypes.map((type) => (
                <option value={type.toLowerCase().replace(" ", "-")}>{type}</option>
              ))}
            </select>
          </div>

          <div class="flex-1">
            <label for="town" class="block text-sm font-medium text-gray-700 mb-1">
              Town / Area
            </label>
            <select
              id="town"
              name="town"
              class="w-full px-4 py-2.5 border border-navy rounded-md bg-white text-gray-800 focus:ring-2 focus:ring-gold focus:border-gold transition-colors"
              aria-label="Filter by town or area"
            >
              {towns.map((town) => (
                <option value={town.toLowerCase()}>{town}</option>
              ))}
            </select>
          </div>

          <div class="flex-1">
            <label for="price-range" class="block text-sm font-medium text-gray-700 mb-1">
              Price Range
            </label>
            <select
              id="price-range"
              name="price-range"
              class="w-full px-4 py-2.5 border border-navy rounded-md bg-white text-gray-800 focus:ring-2 focus:ring-gold focus:border-gold transition-colors"
              aria-label="Filter by price range"
            >
              {priceRanges.map((range) => (
                <option value={range.toLowerCase().replace(/[\$\s–+]/g, "")}>{range}</option>
              ))}
            </select>
          </div>
        </form>
      </div>
    </section>

    <!-- Listings Grid -->
    <section class="py-12 lg:py-16" aria-labelledby="listings-heading">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 id="listings-heading" class="sr-only">Property Listings</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {listings.map((listing) => (
            <article class="bg-white rounded-lg shadow-md overflow-hidden border border-gray-200 hover:shadow-lg transition-shadow">
              <!-- Property Image -->
              <div class="relative aspect-[4/3] bg-gray-300">
                <div 
                  class="absolute inset-0 flex items-center justify-center text-gray-500"
                  role="img"
                  aria-label={`Photo of property at ${listing.address}`}
                >
                  <svg class="w-16 h-16" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                    <polyline stroke-linecap="round" stroke-linejoin="round" stroke-width="1" points="9,22 9,12 15,12 15,22" />
                  </svg>
                </div>
                <!-- Status Badge -->
                <span class="absolute top-3 left-3 px-3 py-1 bg-gold text-navy text-sm font-semibold rounded">
                  {listing.status}
                </span>
              </div>

              <!-- Property Details -->
              <div class="p-5">
                <h3 class="text-gray-700 font-medium mb-2">
                  {listing.address}
                </h3>
               <p class="text-xl font-semibold text-navy mb-4">
                  {listing.price}
                </p>

                <!-- Stats Row - Non-Land Properties -->
                {listing.type !== "Land" && (
                  <div class="flex items-center gap-4 text-sm text-gray-600 mb-4">
                    <span class="flex items-center gap-1.5" aria-label={`${listing.beds} bedrooms`}>
                      <svg class="w-4 h-4 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                      </svg>
                      <span>{listing.beds} {listing.beds === 1 ? "Bed" : "Beds"}</span>
                    </span>
                    <span class="flex items-center gap-1.5" aria-label={`${listing.baths} bathrooms`}>
                      <svg class="w-4 h-4 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z" />
                      </svg>
                      <span>{listing.baths} {listing.baths === 1 ? "Bath" : "Baths"}</span>
                    </span>
                    <span class="flex items-center gap-1.5" aria-label={`${listing.sqft} square feet`}>
                      <svg class="w-4 h-4 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
                      </svg>
                      <span>{listing.sqft} sqft</span>
                    </span>
                  </div>
                )}
                
                <!-- Stats Row - Land Properties -->
                {listing.type === "Land" && (
                  <div class="flex items-center gap-1.5 text-sm text-gray-600 mb-4" aria-label={`${listing.sqft} lot size`}>
                    <svg class="w-4 h-4 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
                    </svg>
                    <span>{listing.sqft}</span>
                  </div>
                )}

                <!-- Property Type Tag -->
                <span class="inline-block px-3 py-1 bg-gray-100 text-gray-700 text-sm rounded mb-4">
                  {listing.type}
                </span>

                <!-- View Details Button -->
                <a
                  href={`/listings/${listing.id}`}
                  class="block w-full text-center px-6 py-3 bg-gold hover:bg-gold-dark text-navy font-semibold rounded-md transition-colors focus-visible:ring-2 focus-visible:ring-gold focus-visible:ring-offset-2"
                  aria-label={`View details for ${listing.address}`}
                >
                  View Details
                </a>
              </div>
            </article>
          ))}
        </div>

        <!-- Pagination -->
        <nav class="mt-12 flex items-center justify-center gap-2" aria-label="Pagination">
          <a
            href="#"
            class="px-4 py-2 border border-navy text-navy rounded-md hover:bg-navy hover:text-white transition-colors focus-visible:ring-2 focus-visible:ring-gold focus-visible:ring-offset-2"
            aria-label="Go to previous page"
          >
            <span class="sr-only">Previous</span>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
          </a>
          
          <a
            href="#"
            class="px-4 py-2 bg-navy text-white rounded-md font-medium focus-visible:ring-2 focus-visible:ring-gold focus-visible:ring-offset-2"
            aria-label="Page 1, current page"
            aria-current="page"
          >
            1
          </a>
          <a
            href="#"
            class="px-4 py-2 border border-navy text-navy rounded-md hover:bg-navy hover:text-white transition-colors focus-visible:ring-2 focus-visible:ring-gold focus-visible:ring-offset-2"
            aria-label="Go to page 2"
          >
            2
          </a>
          <a
            href="#"
            class="px-4 py-2 border border-navy text-navy rounded-md hover:bg-navy hover:text-white transition-colors focus-visible:ring-2 focus-visible:ring-gold focus-visible:ring-offset-2"
            aria-label="Go to page 3"
          >
            3
          </a>
          
          <a
            href="#"
            class="px-4 py-2 border border-navy text-navy rounded-md hover:bg-navy hover:text-white transition-colors focus-visible:ring-2 focus-visible:ring-gold focus-visible:ring-offset-2"
            aria-label="Go to next page"
          >
            <span class="sr-only">Next</span>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </nav>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
