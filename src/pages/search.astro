---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Search | North Country Realty Group" description="Search North Country Realty Group for listings, agents, and local real estate information in Lancaster, NH and the surrounding North Country region.">
  <Header />

  <main id="main-content">
    <!-- Hero Banner -->
    <section class="relative py-20 md:py-28 bg-navy overflow-hidden" aria-labelledby="search-heading">
      <div class="absolute inset-0" aria-hidden="true">
        <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-gold/10 to-transparent"></div>
        <div class="absolute bottom-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-gold/30 to-transparent"></div>
      </div>
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
        <p class="text-gold font-semibold uppercase tracking-widest text-sm mb-3">Search</p>
        <h1 id="search-heading" class="font-heading text-4xl md:text-5xl font-bold text-white mb-6">
          What Are You Looking For?
        </h1>
        <div class="max-w-xl mx-auto">
          <form action="/search" method="get" role="search" class="flex gap-3">
            <label for="hero-search" class="sr-only text-white">Search North Country Realty Group</label>
            <input
              type="search"
              id="hero-search"
              name="q"
              placeholder="Search listings, locations, agents..."
              autocomplete="off"
              class="flex-1 px-5 py-4 bg-white border border-gray-200 rounded-lg text-navy placeholder-gray-400 text-base focus:outline-none focus:ring-2 focus:ring-gold min-width-0"
            />
            <button
              type="submit"
              class="inline-flex items-center gap-2 bg-gold hover:bg-gold-dark text-navy font-bold px-6 py-4 rounded-lg transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-navy whitespace-nowrap"
            >
              <svg class="h-5 w-5" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <circle cx="11" cy="11" r="8"/>
                <path d="M21 21l-4.35-4.35"/>
              </svg>
              Search
            </button>
          </form>
        </div>
      </div>
    </section>

    <!-- Results Section -->
    <section class="py-12 bg-gray-50 min-h-[60vh]" aria-label="Search results">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

        <div id="search-status" class="mb-6 min-h-6"></div>
        <div id="search-results-list" aria-live="polite" aria-label="Search results"></div>

        <!-- Quick Links shown when no search -->
        <div id="quick-links">
          <p class="text-sm font-semibold uppercase tracking-widest text-gold mb-4">Quick Links</p>
          <div id="quick-grid">
            <a href="/listings" class="quick-card">
              <div class="quick-icon" aria-hidden="true">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
                  <polyline points="9,22 9,12 15,12 15,22"/>
                </svg>
              </div>
              <div>
                <div class="quick-title">Browse Listings</div>
                <div class="quick-desc">View all available properties in the North Country</div>
              </div>
            </a>
            <a href="/about" class="quick-card">
              <div class="quick-icon" aria-hidden="true">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                  <circle cx="12" cy="7" r="4"/>
                </svg>
              </div>
              <div>
                <div class="quick-title">Meet Our Team</div>
                <div class="quick-desc">Our experienced local real estate agents</div>
              </div>
            </a>
            <a href="/contact" class="quick-card">
              <div class="quick-icon" aria-hidden="true">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                  <polyline points="22,6 12,13 2,6"/>
                </svg>
              </div>
              <div>
                <div class="quick-title">Contact Us</div>
                <div class="quick-desc">Get in touch with our team</div>
              </div>
            </a>
            <a href="/contact#consultation" class="quick-card" style="border-color:#C9A84C;">
              <div class="quick-icon" style="background:#f5f0e8;color:#C9A84C;" aria-hidden="true">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="4" width="18" height="18" rx="2"/>
                  <line x1="16" y1="2" x2="16" y2="6"/>
                  <line x1="8" y1="2" x2="8" y2="6"/>
                  <line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
              </div>
              <div>
                <div class="quick-title" style="color:#C9A84C;">Schedule a Consultation</div>
                <div class="quick-desc">Book a free consultation with an agent</div>
              </div>
            </a>
          </div>
        </div>

      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style is:global>
  #quick-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .quick-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    padding: 1.25rem;
    text-decoration: none;
    transition: box-shadow 0.2s, transform 0.2s, border-color 0.2s;
  }

  .quick-card:hover {
    box-shadow: 0 4px 12px rgba(201,168,76,0.15);
    transform: translateY(-1px);
    border-color: #C9A84C;
  }

  .quick-icon {
    display: flex;
    height: 2.5rem;
    width: 2.5rem;
    min-width: 2.5rem;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    background: #f5f0e8;
    color: #C9A84C;
    flex-shrink: 0;
  }

  .quick-icon svg {
    height: 1.25rem;
    width: 1.25rem;
  }

  .quick-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: #1B2A4A;
    margin-bottom: 0.2rem;
  }

  .quick-desc {
    font-size: 0.8rem;
    color: #6b7280;
    line-height: 1.5;
  }

  .result-card {
    display: block;
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    padding: 1.25rem 1.5rem;
    text-decoration: none;
    transition: box-shadow 0.2s, transform 0.2s, border-color 0.2s;
    margin-bottom: 1rem;
  }

  .result-card:hover {
    box-shadow: 0 4px 12px rgba(201,168,76,0.15);
    transform: translateY(-1px);
    border-color: #C9A84C;
  }

  /* Fixed: color #92690a → #78350f (amber-900) passes contrast on light highlight background */
  .result-excerpt mark {
    background: rgba(201,168,76,0.15);
    color: #78350f;
    border-radius: 2px;
    padding: 0 2px;
  }

  @media (max-width: 640px) {
    #quick-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  async function runSearch() {
    const params = new URLSearchParams(window.location.search);
    const query = params.get('q')?.trim() ?? '';
    const statusEl = document.getElementById('search-status');
    const resultsEl = document.getElementById('search-results-list');
    const quickLinks = document.getElementById('quick-links');
    const heroInput = document.getElementById('hero-search') as HTMLInputElement;

    if (heroInput && query) heroInput.value = query;

    if (!query || !statusEl || !resultsEl || !quickLinks) return;

    resultsEl.style.minHeight = '300px';
    quickLinks.hidden = true;
    statusEl.innerHTML = '<p style="color:#6b7280;font-size:0.9rem;">Searching...</p>';
    resultsEl.innerHTML = `
      <div style="display:flex;flex-direction:column;gap:1rem;">
        ${[1,2,3].map(() => `
          <div style="background:white;border:1px solid #e5e7eb;border-radius:0.75rem;padding:1.25rem 1.5rem;">
            <div style="height:1.25rem;background:#f3f4f6;border-radius:0.25rem;width:40%;margin-bottom:0.5rem;"></div>
            <div style="height:0.75rem;background:#f3f4f6;border-radius:0.25rem;width:25%;margin-bottom:0.75rem;"></div>
            <div style="height:0.875rem;background:#f3f4f6;border-radius:0.25rem;width:90%;margin-bottom:0.375rem;"></div>
            <div style="height:0.875rem;background:#f3f4f6;border-radius:0.25rem;width:75%;"></div>
          </div>
        `).join('')}
      </div>
    `;

    let pagefind: any;
    try {
      // @ts-ignore
      pagefind = await import(/* @vite-ignore */ '/pagefind/pagefind.js');
    } catch {
      statusEl.innerHTML = '<p style="color:#6b7280;font-size:0.9rem;">Search index not available. Try again on the live site.</p>';
      resultsEl.style.minHeight = '0';
      quickLinks.hidden = false;
      return;
    }

    try {
      const results = await pagefind.search(query);
      const data = await Promise.all(results.results.map((r: any) => r.data()));

      if (data.length === 0) {
        statusEl.innerHTML = '';
        resultsEl.innerHTML = `
          <div style="text-align:center;padding:3rem 1.5rem;background:white;border:1px solid #e5e7eb;border-radius:0.75rem;margin-bottom:2rem;">
            <span style="font-size:3rem;display:block;margin-bottom:1rem;">🔍</span>
            <h2 style="font-size:1.25rem;font-weight:700;color:#1B2A4A;margin-bottom:0.5rem;">No results for "${query}"</h2>
            <p style="font-size:0.9rem;color:#6b7280;margin-bottom:1.5rem;">Try a different search term or browse our listings below.</p>
            <a href="/listings" style="display:inline-flex;align-items:center;gap:0.5rem;background:#C9A84C;color:#1B2A4A;font-weight:700;padding:0.75rem 1.5rem;border-radius:0.5rem;text-decoration:none;font-size:0.9rem;">Browse All Listings</a>
          </div>
        `;
        quickLinks.hidden = false;
        return;
      }

      statusEl.innerHTML = `<p style="color:#6b7280;font-size:0.9rem;margin-bottom:1.5rem;"><strong style="color:#1B2A4A;">${data.length}</strong> result${data.length === 1 ? '' : 's'} for "<strong style="color:#92690a;">${query}</strong>"</p>`;

      resultsEl.innerHTML = data.map((item: any) => `
        <a href="${item.url}" class="result-card">
          <div style="font-size:1.1rem;font-weight:700;color:#1B2A4A;margin-bottom:0.375rem;">${item.meta?.title ?? 'North Country Realty Group'}</div>
          <div style="font-size:0.75rem;color:#15803d;margin-bottom:0.5rem;font-weight:500;">pro3.jakefixestech.com${item.url}</div>
          <div class="result-excerpt" style="font-size:0.9rem;color:#4b5563;line-height:1.6;">${item.excerpt ?? ''}</div>
        </a>
      `).join('');
    } catch (err) {
      statusEl.innerHTML = '<p style="color:#6b7280;font-size:0.9rem;">Something went wrong. Please try again.</p>';
      resultsEl.style.minHeight = '0';
      quickLinks.hidden = false;
    }
  }

  runSearch();
</script>