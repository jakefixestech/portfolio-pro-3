---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Terms of Service | North Country Realty Group">
  <Header />
  
  <main id="main-content">
    <!-- Hero Section -->
    <section class="bg-navy py-16 relative">
      <div class="absolute bottom-0 left-0 right-0 h-1 bg-gold"></div>
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="font-heading text-4xl md:text-5xl text-white mb-4">Terms of Service</h1>
        <p class="text-white text-lg">Last updated: January 1, 2025</p>
      </div>
    </section>

    <!-- Content -->
    <article class="py-16 bg-white">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 prose-content">
        
        <section class="mb-12">
          <h2 class="font-heading text-2xl text-navy mb-4">Acceptance of Terms</h2>
          <p class="text-gray-700 leading-relaxed mb-4">
            By accessing and using the North Country Realty Group website, you accept and agree to be bound by these Terms of Service. If you do not agree to these terms, please do not use our website.
          </p>
          <p class="text-gray-700 leading-relaxed">
            These terms apply to all visitors, users, and others who access or use our website. We reserve the right to update or modify these terms at any time without prior notice.
          </p>
        </section>

        <section class="mb-12">
          <h2 class="font-heading text-2xl text-navy mb-4">Use of This Website</h2>
          <p class="text-gray-700 leading-relaxed mb-4">
            You agree to use this website only for lawful purposes and in a way that does not infringe upon the rights of others or restrict their use of the website. Prohibited uses include:
          </p>
          <ul class="list-disc list-inside text-gray-700 space-y-2 ml-4">
            <li>Using the website in any way that violates applicable local, state, or federal laws</li>
            <li>Attempting to gain unauthorized access to any portion of the website</li>
            <li>Interfering with the proper functioning of the website</li>
            <li>Collecting or harvesting any personally identifiable information from the website</li>
            <li>Using the website to transmit spam, chain letters, or other unsolicited communications</li>
          </ul>
        </section>

        <section class="mb-12">
          <h2 class="font-heading text-2xl text-navy mb-4">Listing Information Disclaimer</h2>
          <p class="text-gray-700 leading-relaxed mb-4">
            <strong>Important Notice:</strong> All property listings displayed on this website are for demonstration purposes only and do not represent actual properties currently for sale or rent. The images, prices, descriptions, and other details shown are fictional examples used to illustrate our website functionality.
          </p>
          <p class="text-gray-700 leading-relaxed mb-4">
            For actual property listings and real estate services in the North Country region of New Hampshire, please contact our office directly. We will be happy to provide you with current, accurate information about available properties.
          </p>
          <p class="text-gray-700 leading-relaxed">
            North Country Realty Group makes no representations or warranties regarding the accuracy, completeness, or availability of any demonstration listing information displayed on this website.
          </p>
        </section>

        <section class="mb-12">
          <h2 class="font-heading text-2xl text-navy mb-4">Intellectual Property</h2>
          <p class="text-gray-700 leading-relaxed mb-4">
            All content on this website, including but not limited to text, graphics, logos, images, and software, is the property of North Country Realty Group or its content suppliers and is protected by United States and international copyright laws.
          </p>
          <p class="text-gray-700 leading-relaxed">
            You may not reproduce, distribute, modify, create derivative works of, publicly display, or otherwise use any content from this website without our prior written consent, except for personal, non-commercial use.
          </p>
        </section>

        <section class="mb-12">
          <h2 class="font-heading text-2xl text-navy mb-4">Limitation of Liability</h2>
          <p class="text-gray-700 leading-relaxed mb-4">
            North Country Realty Group shall not be liable for any direct, indirect, incidental, special, consequential, or punitive damages arising out of your access to or use of this website. This includes, but is not limited to, damages for errors, omissions, interruptions, defects, delays, or any other performance failures.
          </p>
          <p class="text-gray-700 leading-relaxed">
            We do not warrant that this website will be uninterrupted, error-free, or free of viruses or other harmful components. You use this website at your own risk.
          </p>
        </section>

        <section class="mb-12">
          <h2 class="font-heading text-2xl text-navy mb-4">Third Party Links</h2>
          <p class="text-gray-700 leading-relaxed mb-4">
            This website may contain links to third-party websites or services that are not owned or controlled by North Country Realty Group. We have no control over, and assume no responsibility for, the content, privacy policies, or practices of any third-party websites or services.
          </p>
          <p class="text-gray-700 leading-relaxed">
            We encourage you to review the terms and privacy policies of any third-party websites you visit through links on our website.
          </p>
        </section>

        <section class="mb-12">
          <h2 class="font-heading text-2xl text-navy mb-4">Changes to Terms</h2>
          <p class="text-gray-700 leading-relaxed mb-4">
            We reserve the right to modify or replace these Terms of Service at any time at our sole discretion. If we make material changes, we will update the "Last updated" date at the top of this page.
          </p>
          <p class="text-gray-700 leading-relaxed">
            Your continued use of the website after any changes to these terms constitutes your acceptance of the new Terms of Service.
          </p>
        </section>

        <section class="mb-12">
          <h2 class="font-heading text-2xl text-navy mb-4">Contact Us</h2>
          <p class="text-gray-700 leading-relaxed mb-4">
            If you have any questions about these Terms of Service, please contact us:
          </p>
          <address class="text-gray-700 not-italic leading-relaxed">
            <strong class="text-navy">North Country Realty Group</strong><br>
            123 Main Street<br>
            Lancaster, NH 03584<br><br>
            Phone: <a href="tel:+16037881234" class="text-navy hover:text-gold transition-colors">(603) 788-1234</a><br>
            Email: <a href="mailto:info@northcountryrealty.com" class="text-navy hover:text-gold transition-colors">info@northcountryrealty.com</a>
          </address>
        </section>

        <!-- Back to Home Link -->
        <div class="pt-8 border-t border-gray-200">
          <a 
            href="/" 
            class="inline-flex items-center gap-2 text-navy hover:text-gold transition-colors font-medium focus:outline-none focus-visible:ring-2 focus-visible:ring-gold focus-visible:ring-offset-2 rounded"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back to Home
          </a>
        </div>

      </div>
    </article>
  </main>

  <Footer />
</Layout>