---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const property = {
  address: "47 Pine Street",
  city: "Lancaster",
  state: "NH",
  zip: "03584",
  price: "$325,000",
  beds: 3,
  baths: 2,
  sqft: "1,850",
  acres: "0.35",
  type: "Single Family",
  status: "Active",
  mls: "4987321",
  yearBuilt: "1985",
  garage: "2-Car Attached",
  heating: "Forced Hot Air, Oil",
  cooling: "None",
  schoolDistrict: "White Mountains Regional",
};

const similarListings = [
  {
    id: 2,
    address: "182 Main Street, Whitefield, NH",
    price: "$275,000",
    beds: 4,
    baths: 2.5,
    sqft: "2,100",
  },
  {
    id: 3,
    address: "15 Mountain View Dr, Jefferson, NH",
    price: "$450,000",
    beds: 5,
    baths: 3,
    sqft: "3,200",
  },
  {
    id: 4,
    address: "89 River Road, Groveton, NH",
    price: "$189,000",
    beds: 2,
    baths: 1,
    sqft: "1,200",
  },
];
---

<Layout title={`${property.address}, ${property.city}, ${property.state} | North Country Realty Group`}>
  <Header />
  
  <main id="main-content" class="flex-1">
    <!-- Breadcrumb Navigation -->
    <nav aria-label="Breadcrumb" class="bg-gray-50 border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
        <ol class="flex items-center gap-2 text-sm">
          <li>
            <a href="/" class="text-gray-600 hover:text-navy transition-colors">
              Home
            </a>
          </li>
          <li class="text-gray-400" aria-hidden="true">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </li>
          <li>
            <a href="/listings" class="text-gray-600 hover:text-navy transition-colors">
              Listings
            </a>
          </li>
          <li class="text-gray-400" aria-hidden="true">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </li>
          <li>
            <span class="text-navy font-medium" aria-current="page">
              {property.address}
            </span>
          </li>
        </ol>
      </div>
    </nav>

    <!-- Property Header -->
    <section class="bg-white border-b border-gray-200 py-8">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-6">
          <!-- Left: Address, Type, Status, Price -->
          <div>
            <div class="flex flex-wrap items-center gap-3 mb-3">
              <span class="inline-block px-3 py-1 bg-gray-100 text-gray-700 text-sm font-medium rounded">
                {property.type}
              </span>
              <span class="inline-block px-3 py-1 bg-gold text-navy text-sm font-semibold rounded">
                {property.status}
              </span>
            </div>
            <h1 class="font-heading text-2xl sm:text-3xl lg:text-4xl font-bold text-navy mb-2">
              {property.address}, {property.city}, {property.state}
            </h1>
            <p class="text-3xl sm:text-4xl font-heading font-bold text-gold">
              {property.price}
            </p>
          </div>

          <!-- Right: Action Buttons -->
          <div class="flex flex-col sm:flex-row gap-3 lg:flex-shrink-0">
            <a
              href="/contact#consultation"
              class="inline-flex items-center justify-center px-6 py-3 bg-gold hover:bg-gold-dark text-navy font-semibold rounded-md transition-colors focus-visible:ring-2 focus-visible:ring-gold focus-visible:ring-offset-2"
            >
              Schedule a Showing
            </a>
            <a
              href="/listings"
              class="inline-flex items-center justify-center px-6 py-3 border-2 border-navy text-navy hover:bg-navy hover:text-white font-semibold rounded-md transition-colors focus-visible:ring-2 focus-visible:ring-navy focus-visible:ring-offset-2"
            >
              Back to Listings
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Image Gallery -->
    <section class="py-8 bg-white" aria-label="Property photos">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Main Image -->
        <div 
          class="relative aspect-video bg-navy rounded-lg overflow-hidden mb-4 flex items-center justify-center"
          role="img"
          aria-label="Property photo 1 of 4 — front exterior of 47 Pine Street"
        >
          <svg class="w-24 h-24 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
            <polyline stroke-linecap="round" stroke-linejoin="round" stroke-width="1" points="9,22 9,12 15,12 15,22" />
          </svg>
        </div>

        <!-- Thumbnail Row -->
        <div class="grid grid-cols-3 gap-4">
          <div 
            class="relative aspect-video bg-gray-300 rounded-lg overflow-hidden flex items-center justify-center cursor-pointer hover:opacity-80 transition-opacity"
            role="img"
            aria-label="Property photo 2 of 4 — kitchen interior"
          >
            <svg class="w-10 h-10 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
              <polyline stroke-linecap="round" stroke-linejoin="round" stroke-width="1" points="9,22 9,12 15,12 15,22" />
            </svg>
          </div>
          <div 
            class="relative aspect-video bg-gray-300 rounded-lg overflow-hidden flex items-center justify-center cursor-pointer hover:opacity-80 transition-opacity"
            role="img"
            aria-label="Property photo 3 of 4 — living room"
          >
            <svg class="w-10 h-10 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
              <polyline stroke-linecap="round" stroke-linejoin="round" stroke-width="1" points="9,22 9,12 15,12 15,22" />
            </svg>
          </div>
          <div 
            class="relative aspect-video bg-gray-300 rounded-lg overflow-hidden flex items-center justify-center cursor-pointer hover:opacity-80 transition-opacity"
            role="img"
            aria-label="Property photo 4 of 4 — backyard with mountain views"
          >
            <svg class="w-10 h-10 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
              <polyline stroke-linecap="round" stroke-linejoin="round" stroke-width="1" points="9,22 9,12 15,12 15,22" />
            </svg>
          </div>
        </div>
      </div>
    </section>

    <!-- Two Column Detail Layout -->
    <section class="py-12 lg:py-16 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-12">
          <!-- Left Column: Property Details (wider) -->
          <div class="lg:col-span-2 space-y-10">
            <!-- Stats Bar -->
            <div class="bg-white rounded-lg p-6 shadow-sm border border-gray-200">
              <div class="grid grid-cols-2 sm:grid-cols-4 gap-6">
                <div class="flex items-center gap-3">
                  <div class="flex-shrink-0 w-10 h-10 rounded-full bg-gold/10 flex items-center justify-center">
                    <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-label="Bedrooms">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-2xl font-heading font-bold text-navy">{property.beds}</p>
                    <p class="text-sm text-gray-600">Beds</p>
                  </div>
                </div>

                <div class="flex items-center gap-3">
                  <div class="flex-shrink-0 w-10 h-10 rounded-full bg-gold/10 flex items-center justify-center">
                    <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-label="Bathrooms">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-2xl font-heading font-bold text-navy">{property.baths}</p>
                    <p class="text-sm text-gray-600">Baths</p>
                  </div>
                </div>

                <div class="flex items-center gap-3">
                  <div class="flex-shrink-0 w-10 h-10 rounded-full bg-gold/10 flex items-center justify-center">
                    <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-label="Square footage">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-2xl font-heading font-bold text-navy">{property.sqft}</p>
                    <p class="text-sm text-gray-600">Sq Ft</p>
                  </div>
                </div>

                <div class="flex items-center gap-3">
                  <div class="flex-shrink-0 w-10 h-10 rounded-full bg-gold/10 flex items-center justify-center">
                    <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-label="Lot size">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-2xl font-heading font-bold text-navy">{property.acres}</p>
                    <p class="text-sm text-gray-600">Acres</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Overview Section -->
            <div>
              <h2 class="font-heading text-2xl font-bold text-navy mb-4">Overview</h2>
              <div class="prose prose-gray max-w-none">
                <p class="text-gray-700 leading-relaxed mb-4">
                  Welcome to this charming 3-bedroom, 2-bathroom single-family home nestled in the heart of Lancaster, NH. This well-maintained property offers the perfect blend of comfort and convenience, situated on a generous 0.35-acre lot with stunning mountain views that showcase the beauty of the White Mountains region.
                </p>
                <p class="text-gray-700 leading-relaxed mb-4">
                  Step inside to discover a thoughtfully updated interior featuring a renovated kitchen with modern appliances, granite countertops, and ample cabinet space. The open-concept living area is bathed in natural light, creating a warm and inviting atmosphere perfect for everyday living and entertaining guests.
                </p>
                <p class="text-gray-700 leading-relaxed">
                  Located just minutes from downtown Lancaster, you'll enjoy easy access to local shops, restaurants, and recreational activities. Whether you're seeking a peaceful retreat or a place to call home year-round, this property offers the quintessential North Country lifestyle with all the amenities you need.
                </p>
              </div>
            </div>

            <!-- Property Details Section -->
            <div>
              <h2 class="font-heading text-2xl font-bold text-navy mb-4">Property Details</h2>
              <div class="bg-white rounded-lg p-6 shadow-sm border border-gray-200">
                <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-4">
                  <div class="flex justify-between sm:block">
                    <dt class="text-gray-600 font-medium">MLS#</dt>
                    <dd class="text-navy font-semibold">{property.mls}</dd>
                  </div>
                  <div class="flex justify-between sm:block">
                    <dt class="text-gray-600 font-medium">Year Built</dt>
                    <dd class="text-navy font-semibold">{property.yearBuilt}</dd>
                  </div>
                  <div class="flex justify-between sm:block">
                    <dt class="text-gray-600 font-medium">Lot Size</dt>
                    <dd class="text-navy font-semibold">{property.acres} acres</dd>
                  </div>
                  <div class="flex justify-between sm:block">
                    <dt class="text-gray-600 font-medium">Garage</dt>
                    <dd class="text-navy font-semibold">{property.garage}</dd>
                  </div>
                  <div class="flex justify-between sm:block">
                    <dt class="text-gray-600 font-medium">Heating</dt>
                    <dd class="text-navy font-semibold">{property.heating}</dd>
                  </div>
                  <div class="flex justify-between sm:block">
                    <dt class="text-gray-600 font-medium">Cooling</dt>
                    <dd class="text-navy font-semibold">{property.cooling}</dd>
                  </div>
                  <div class="flex justify-between sm:block sm:col-span-2">
                    <dt class="text-gray-600 font-medium">School District</dt>
                    <dd class="text-navy font-semibold">{property.schoolDistrict}</dd>
                  </div>
                </dl>
              </div>
            </div>

            <!-- Location Section -->
            <div>
              <h2 class="font-heading text-2xl font-bold text-navy mb-4">Location</h2>
              <div class="rounded-xl bg-navy p-8 flex flex-col items-center justify-center min-h-[250px]">
                <svg class="w-12 h-12 text-gold mb-3" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" />
                </svg>
                <p class="text-white font-semibold text-center text-lg">{property.address}</p>
                <p class="text-slate-300 text-center">{property.city}, {property.state} {property.zip}</p>
              </div>
            </div>
          </div>

          <!-- Right Column: Agent Card (sticky) -->
          <div class="lg:col-span-1">
            <div class="lg:sticky lg:top-8">
              <div class="bg-white rounded-lg p-6 shadow-sm border border-gray-200">
                <!-- Agent Info -->
                <div class="flex items-center gap-4 mb-6">
                  <div class="flex-shrink-0 w-16 h-16 rounded-full bg-navy flex items-center justify-center text-white font-heading font-bold text-xl">
                    MH
                  </div>
                  <div>
                    <p class="font-heading font-bold text-navy text-lg">Margaret Hayes</p>
                    <p class="text-gray-600 text-sm">Broker/Owner</p>
                  </div>
                </div>

                <!-- Contact Links -->
                <div class="space-y-3 mb-6">
                  <a
                    href="tel:+16037881234"
                    class="flex items-center gap-3 text-gray-700 hover:text-gold transition-colors"
                  >
                    <svg class="w-5 h-5 text-gold flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                    </svg>
                    <span>(603) 788-1234</span>
                  </a>
                  <a
                    href="mailto:margaret@northcountryrealty.com"
                    class="flex items-center gap-3 text-gray-700 hover:text-gold transition-colors"
                  >
                    <svg class="w-5 h-5 text-gold flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                    <span>margaret@northcountryrealty.com</span>
                  </a>
                </div>

                <!-- Action Buttons -->
                <div class="space-y-3">
                  <a
                    href="/contact#consultation"
                    class="block w-full text-center px-6 py-3 bg-gold hover:bg-gold-dark text-navy font-semibold rounded-md transition-colors focus-visible:ring-2 focus-visible:ring-gold focus-visible:ring-offset-2"
                  >
                    Schedule a Showing
                  </a>
                  <a
                    href="/contact"
                    class="block w-full text-center px-6 py-3 border-2 border-navy text-navy hover:bg-navy hover:text-white font-semibold rounded-md transition-colors focus-visible:ring-2 focus-visible:ring-navy focus-visible:ring-offset-2"
                  >
                    Request More Info
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Similar Listings -->
    <section class="py-12 lg:py-16 bg-white" aria-labelledby="similar-listings-heading">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 id="similar-listings-heading" class="font-heading text-2xl lg:text-3xl font-bold text-navy mb-8">
          Similar Properties
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {similarListings.map((listing) => (
            <article class="bg-white rounded-lg shadow-md overflow-hidden border border-gray-200 hover:shadow-lg transition-shadow">
              <!-- Property Image -->
              <div class="relative aspect-[4/3] bg-gray-300">
                <div 
                  class="absolute inset-0 flex items-center justify-center text-gray-500"
                  role="img"
                  aria-label={`Photo of property at ${listing.address}`}
                >
                  <svg class="w-16 h-16" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                    <polyline stroke-linecap="round" stroke-linejoin="round" stroke-width="1" points="9,22 9,12 15,12 15,22" />
                  </svg>
                </div>
                <!-- Status Badge -->
                <span class="absolute top-3 left-3 px-3 py-1 bg-gold text-navy text-sm font-semibold rounded">
                  Active
                </span>
              </div>

              <!-- Property Details -->
              <div class="p-5">
                <h3 class="text-gray-700 font-medium mb-2">
                  {listing.address}
                </h3>
                <p class="text-2xl font-heading font-bold text-navy mb-4">
                  {listing.price}
                </p>

                <!-- Stats Row -->
                <div class="flex items-center gap-4 text-sm text-gray-600 mb-4">
                  <span class="flex items-center gap-1.5" aria-label={`${listing.beds} bedrooms`}>
                    <svg class="w-4 h-4 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                    </svg>
                    <span>{listing.beds} {listing.beds === 1 ? "Bed" : "Beds"}</span>
                  </span>
                  <span class="flex items-center gap-1.5" aria-label={`${listing.baths} bathrooms`}>
                    <svg class="w-4 h-4 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z" />
                    </svg>
                    <span>{listing.baths} {listing.baths === 1 ? "Bath" : "Baths"}</span>
                  </span>
                  <span class="flex items-center gap-1.5" aria-label={`${listing.sqft} square feet`}>
                    <svg class="w-4 h-4 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
                    </svg>
                    <span>{listing.sqft} sqft</span>
                  </span>
                </div>

                <!-- View Details Button -->
                <a
                  href={`/listings/${listing.id}`}
                  class="block w-full text-center px-6 py-3 bg-gold hover:bg-gold-dark text-navy font-semibold rounded-md transition-colors focus-visible:ring-2 focus-visible:ring-gold focus-visible:ring-offset-2"
                  aria-label={`View details for ${listing.address}`}
                >
                  View Details
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
