---
const navLinks = [
  { href: "/listings", label: "Listings" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
---

<header class="bg-white shadow-sm sticky top-0 z-50 transition-transform duration-300" role="banner">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" aria-label="Main navigation">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a 
        href="/" 
        class="flex items-center gap-2 text-navy font-heading font-bold text-lg sm:text-xl lg:text-2xl hover:text-navy-light transition-colors"
        aria-label="North Country Realty Group - Home"
      >
        <svg class="w-8 h-8 lg:w-10 lg:h-10 text-gold" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M20 4L4 16V36H16V24H24V36H36V16L20 4Z" fill="currentColor"/>
          <path d="M20 4L4 16V36H16V24H24V36H36V16L20 4Z" stroke="#1B2A4A" stroke-width="2" stroke-linejoin="round"/>
        </svg>
        <span class="hidden sm:inline">North Country Realty Group</span>
        <span class="sm:hidden">NCRG</span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-6">
        <ul class="flex items-center gap-6" role="list">
          {navLinks.map((link) => (
            <li>
              <a 
                href={link.href}
                class="text-gray-700 hover:text-navy font-medium transition-colors py-2 border-b-2 border-transparent hover:border-gold"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>

        <!-- Desktop Search -->
        <div role="search">
          <form action="/search" method="get">
            <label for="desktop-search" class="sr-only">Search North Country Realty Group</label>
            <div class="relative flex items-center">
              <svg
                class="absolute left-3 h-4 w-4 text-gray-400 pointer-events-none"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <circle cx="11" cy="11" r="8" />
                <path d="M21 21l-4.35-4.35" />
              </svg>
              <input
                type="search"
                id="desktop-search"
                name="q"
                placeholder="Search..."
                autocomplete="off"
                class="w-36 focus:w-48 transition-all duration-300 bg-gray-50 border border-gray-300 rounded-lg pl-9 pr-3 py-2 text-sm text-navy placeholder-gray-400 focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold"
              />
            </div>
          </form>
        </div>

        <a 
          href="/contact#consultation"
          class="inline-flex items-center justify-center px-6 py-2.5 bg-gold hover:bg-gold-dark text-navy font-semibold rounded-md transition-colors focus-visible:ring-2 focus-visible:ring-gold focus-visible:ring-offset-2"
        >
          Schedule a Consultation
        </a>
      </div>

      <!-- Mobile right side: search + menu button -->
      <div class="lg:hidden flex items-center gap-2">
        <!-- Mobile Search Toggle -->
        <button
          type="button"
          id="mobile-search-toggle"
          class="inline-flex items-center justify-center p-2 rounded-md text-navy hover:bg-gray-100 transition-colors"
          aria-label="Open search"
          aria-expanded="false"
          aria-controls="mobile-search-bar"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="11" cy="11" r="8" />
            <path d="M21 21l-4.35-4.35" />
          </svg>
        </button>

        <!-- Mobile Menu Button -->
        <button
          type="button"
          id="mobile-menu-button"
          class="inline-flex items-center justify-center p-2 rounded-md text-navy hover:bg-gray-100 transition-colors"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Toggle navigation menu"
        >
          <svg id="menu-icon-open" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Search Bar -->
    <div id="mobile-search-bar" class="hidden lg:hidden pb-3" role="search">
      <form action="/search" method="get" class="flex gap-2">
        <label for="mobile-search" class="sr-only">Search North Country Realty Group</label>
        <div class="relative flex-1">
          <svg
            class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-gray-400 pointer-events-none"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <circle cx="11" cy="11" r="8" />
            <path d="M21 21l-4.35-4.35" />
          </svg>
          <input
            type="search"
            id="mobile-search"
            name="q"
            placeholder="Search listings, agents..."
            autocomplete="off"
            class="w-full bg-gray-50 border border-gray-300 rounded-lg pl-9 pr-3 py-2.5 text-sm text-navy placeholder-gray-400 focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold"
          />
        </div>
        <button
          type="submit"
          class="bg-gold hover:bg-gold-dark text-navy font-semibold px-4 py-2.5 rounded-lg text-sm transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-gold focus-visible:ring-offset-2"
        >
          Search
        </button>
      </form>
    </div>

    <!-- Mobile Menu -->
    <div 
      id="mobile-menu" 
      class="lg:hidden hidden pb-4"
      role="region"
      aria-label="Mobile navigation"
    >
      <ul class="flex flex-col gap-2 pt-2 border-t border-gray-200" role="list">
        {navLinks.map((link) => (
          <li>
            <a 
              href={link.href}
              class="block px-3 py-2 text-gray-700 hover:text-navy hover:bg-gray-50 font-medium rounded-md transition-colors"
            >
              {link.label}
            </a>
          </li>
        ))}
        <li class="pt-2">
          <a 
            href="/contact#consultation"
            class="block w-full text-center px-6 py-3 bg-gold hover:bg-gold-dark text-navy font-semibold rounded-md transition-colors"
          >
            Schedule a Consultation
          </a>
        </li>
      </ul>
    </div>
  </nav>
</header>

<script>
  // Smart navbar — hide on scroll down, show on scroll up
  let lastScrollY = window.scrollY;
  let ticking = false;
  const header = document.querySelector('header');

  window.addEventListener('scroll', () => {
    if (!ticking) {
      window.requestAnimationFrame(() => {
        const currentScrollY = window.scrollY;

        if (currentScrollY > lastScrollY && currentScrollY > 80) {
          header?.classList.add('-translate-y-full');
          const menuButton = document.getElementById('mobile-menu-button');
          if (menuButton?.getAttribute('aria-expanded') === 'true') {
            menuButton.click();
          }
        } else {
          header?.classList.remove('-translate-y-full');
        }

        lastScrollY = currentScrollY;
        ticking = false;
      });
      ticking = true;
    }
  });

  // Mobile menu toggle
  const menuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-icon-open');
  const closeIcon = document.getElementById('menu-icon-close');

  menuButton?.addEventListener('click', () => {
    const isExpanded = menuButton.getAttribute('aria-expanded') === 'true';
    menuButton.setAttribute('aria-expanded', String(!isExpanded));
    mobileMenu?.classList.toggle('hidden');
    openIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
    menuButton?.focus();
  });

  // Close menu on escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !mobileMenu?.classList.contains('hidden')) {
      menuButton?.setAttribute('aria-expanded', 'false');
      mobileMenu?.classList.add('hidden');
      openIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      menuButton?.focus();
    }
  });

  // Close menu on outside click
  document.addEventListener('click', (e) => {
    const target = e.target as Node;
    if (
      !mobileMenu?.classList.contains('hidden') &&
      !mobileMenu?.contains(target) &&
      !menuButton?.contains(target)
    ) {
      menuButton?.click();
    }
  });

  // Mobile search toggle
  const searchToggle = document.getElementById('mobile-search-toggle');
  const mobileSearchBar = document.getElementById('mobile-search-bar');

  searchToggle?.addEventListener('click', () => {
    const isExpanded = searchToggle.getAttribute('aria-expanded') === 'true';
    searchToggle.setAttribute('aria-expanded', String(!isExpanded));
    searchToggle.setAttribute('aria-label', isExpanded ? 'Open search' : 'Close search');
    mobileSearchBar?.classList.toggle('hidden');
    if (!isExpanded) {
      (mobileSearchBar?.querySelector('input') as HTMLInputElement)?.focus();
    }
  });
</script>